{
  "name": "oqusvpn-server",
  "version": "0.1.0",
  "private": true,
  "description": "OqusVPN control-plane backend — accounts, auth, and Shadowsocks access-key issuance.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mem": "tsx src/dev-mem.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "tsx src/smoke.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "mongodb-memory-server": "^10.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
