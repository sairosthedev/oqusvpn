# OqusVPN backend configuration. Copy to .env and fill in.

# HTTP port the API listens on
PORT=8080

# MongoDB connection string (local Docker, or a MongoDB Atlas SRV URI)
MONGO_URI=mongodb://127.0.0.1:27017/oqusvpn

# Secret used to sign JWTs — MUST be a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=30d

# Shadowsocks access key handed to authenticated users (MVP: one shared test key).
# Swap the StaticKeyProvider for Shadowbox/ss-server provisioning later.
OQUS_ACCESS_KEY=ss://chacha20-ietf-poly1305:oqus-test-pw@127.0.0.1:8388

# CORS origin allowed to call the API (the Electron/web client). * for dev.
CORS_ORIGIN=*

# Admin console login. The account is created/kept with this password on boot.
# NOTE: avoid '#' and spaces in .env values — dotenv treats them as comments.
# Use letters/digits only, or wrap the value in double quotes.
OQUS_ADMIN_EMAIL=you@example.com
OQUS_ADMIN_PASSWORD=UseLettersAndDigitsOnly
