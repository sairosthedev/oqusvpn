{
  "name": "oqusvpn-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "workspaces": [
    "server"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web,app -c cyan,green,magenta \"npm:dev:server\" \"vite --port 5173 --strictPort\" \"wait-on tcp:5173 && cross-env OQUS_DEV=1 electron .\"",
    "dev:web": "concurrently -k -n api,web -c cyan,green \"npm:dev:server\" \"vite\"",
    "dev:client": "vite",
    "dev:server": "npm run dev:mem -w server",
    "build": "tsc -b && vite build",
    "build:server": "npm run build -w server",
    "build:all": "npm run build:server && npm run build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently -k \"vite --port 5173 --strictPort\" \"wait-on tcp:5173 && cross-env OQUS_DEV=1 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "smoke:server": "npm run smoke -w server",
    "ss:server": "node tools/ss-server.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-radio-group": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.20",
    "d3-geo": "^3.1.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "app.oqus.vpn",
    "productName": "OqusVPN",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    }
  }
}
